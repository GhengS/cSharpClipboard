<Window x:Class="ClipboardHistory.Views.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ClipboardHistory.Models"
        xmlns:converters="clr-namespace:ClipboardHistory.Converters"
        mc:Ignorable="d"
        Title="内容详情" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.Page}">
    <Window.Resources>
        <converters:BytesToImageConverter x:Key="BytesToImage" />
        <converters:TypeToVisibilityConverter x:Key="TypeToVisibility" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content Area -->
        <Border Background="{StaticResource Brush.Surface}" 
                BorderBrush="{StaticResource Brush.Border}" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="10">
            <Grid>
                <!-- Text Content -->
                <ScrollViewer Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=Text}">
                    <TextBox Text="{Binding Content, Mode=OneWay}" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource Brush.Text}"
                             FontSize="14" />
                </ScrollViewer>

                <!-- File Content (same as text but styled slightly different) -->
                <ScrollViewer Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=File}">
                    <TextBox Text="{Binding Content, Mode=OneWay}" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource Brush.TextMuted}"
                             FontStyle="Italic"
                             FontSize="14" />
                </ScrollViewer>

                <!-- Image Content -->
                <Image Source="{Binding ImageData, Converter={StaticResource BytesToImage}}" 
                       Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=Image}"
                       Stretch="Uniform" />
            </Grid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="复制内容" 
                    Click="CopyButton_Click"
                    Padding="20,8" 
                    Style="{StaticResource AccentButton}"
                    Margin="0,0,10,0" />
            <Button Content="关闭" 
                    IsCancel="True"
                    Padding="20,8" />
        </StackPanel>
    </Grid>
</Window>
