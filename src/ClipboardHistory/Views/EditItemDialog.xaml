<Window x:Class="ClipboardHistory.Views.EditItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑条目"
        Width="580"
        Height="440"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Brush.Page}"
        FontFamily="{StaticResource Font.Ui}"
        UseLayoutRounding="True">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="修改下方文本后点击确定保存到历史。"
               Foreground="{StaticResource Brush.TextMuted}"
               FontSize="12"
               Margin="0,0,0,12"
               TextWrapping="Wrap" />

    <Border Grid.Row="1"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="2">
      <TextBox x:Name="Editor"
               AcceptsReturn="True"
               AcceptsTab="True"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto"
               TextWrapping="Wrap"
               BorderThickness="0"
               Background="Transparent"
               FontFamily="Cascadia Mono, Consolas, Courier New"
               FontSize="13"
               Padding="12" />
    </Border>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button Content="取消"
              IsCancel="True"
              Width="96"
              Margin="0,0,10,0" />
      <Button Content="确定"
              IsDefault="True"
              Style="{StaticResource AccentButton}"
              Width="96"
              Click="Ok_Click" />
    </StackPanel>
  </Grid>
</Window>
