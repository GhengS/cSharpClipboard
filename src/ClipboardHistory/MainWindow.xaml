<Window x:Class="ClipboardHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ClipboardHistory.Models"
        mc:Ignorable="d"
        Title="剪贴板历史"
        Height="560"
        Width="720"
        MinWidth="520"
        MinHeight="380"
        Background="#FFF7F8FA">
  <Grid Margin="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Padding="12,10"
            Background="#FFEDEDF2"
            BorderBrush="#22000000"
            BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Left"
                    VerticalAlignment="Center">
          <TextBlock Text="视图"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Foreground="#FF444444" />
          <Button Content="列表"
                  Command="{Binding ToggleListViewCommand}"
                  Padding="12,6"
                  Margin="0,0,6,0" />
          <Button Content="卡片"
                  Command="{Binding ToggleCardViewCommand}"
                  Padding="12,6"
                  Margin="0,0,16,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center">
          <Button Content="复制"
                  Command="{Binding CopySelectionCommand}"
                  Padding="12,6"
                  Margin="0,0,6,0"
                  ToolTip="将当前选中第一条写回剪贴板 (Enter)" />
          <Button Content="追加合并"
                  Command="{Binding AppendMergedCommand}"
                  Padding="12,6"
                  Margin="0,0,6,0"
                  ToolTip="将选中多条按设置的分隔符合并到剪贴板" />
          <Button Content="编辑"
                  Command="{Binding EditSelectionCommand}"
                  Padding="12,6"
                  Margin="0,0,6,0" />
          <Button Content="删除"
                  Command="{Binding DeleteSelectionCommand}"
                  Padding="12,6"
                  Margin="0,0,0,0" />
        </StackPanel>

        <Grid Margin="8,0,8,0" VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="搜索"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Foreground="#FF444444" />
          <TextBox Grid.Column="1"
                   MinWidth="200"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   VerticalContentAlignment="Center"
                   Padding="6,4" />
        </Grid>
      </DockPanel>
    </Border>

    <ListBox x:Name="HistoryList"
             Grid.Row="1"
             Margin="12"
             BorderBrush="#22000000"
             SelectionMode="Extended"
             ItemsSource="{Binding Items}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             SelectionChanged="HistoryList_OnSelectionChanged"
             MouseDoubleClick="HistoryList_OnMouseDoubleClick">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.InputBindings>
        <KeyBinding Key="Enter"
                    Command="{Binding CopySelectionCommand}" />
      </ListBox.InputBindings>
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate DataType="{x:Type models:ClipboardItem}">
          <Border Padding="8,6"
                  Margin="0,3"
                  Background="White"
                  BorderBrush="#14000000"
                  BorderThickness="1"
                  CornerRadius="6"
                  SnapsToDevicePixels="True">
            <TextBlock Text="{Binding Preview}"
                       TextTrimming="CharacterEllipsis"
                       Foreground="#FF222222"
                       FontSize="13"
                       TextWrapping="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModeToWrapping}}"
                       MaxHeight="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModeToMaxHeight}}" />
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border Grid.Row="2"
            Padding="12,8"
            Background="#FFEDEDF2"
            BorderBrush="#22000000"
            BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding StatusHint}"
                 Foreground="#FF555555"
                 FontSize="12"
                 TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
