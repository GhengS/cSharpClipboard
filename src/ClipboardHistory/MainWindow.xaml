<Window x:Class="ClipboardHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ClipboardHistory.Models"
        mc:Ignorable="d"
        Title="剪贴板历史"
        Height="600"
        Width="760"
        MinWidth="520"
        MinHeight="400"
        Background="{StaticResource Brush.Page}"
        FontFamily="{StaticResource Font.Ui}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Padding="20,16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="36"
                  Height="36"
                  CornerRadius="10"
                  Background="{StaticResource Brush.Accent}"
                  Margin="0,0,12,0"
                  VerticalAlignment="Center">
            <TextBlock Text="📋"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,-1,0,0" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="剪贴板历史"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}" />
            <TextBlock Text="列表/搜索 · Caps Lock 合并 · Win+V 同步"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"
                       Margin="0,2,0,0" />
          </StackPanel>
        </StackPanel>

        <DockPanel Grid.Row="1" LastChildFill="True" Margin="0,16,0,0">
          <StackPanel Orientation="Horizontal"
                      DockPanel.Dock="Left"
                      VerticalAlignment="Center">
            <TextBlock Text="视图"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}" />
            <Button Content="列表"
                    Command="{Binding ToggleListViewCommand}"
                    Margin="0,0,6,0">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource ViewModeButtonStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ViewMode, Converter={StaticResource ViewModeToBool}, ConverterParameter=List}" Value="True">
                      <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                      <Setter Property="Foreground" Value="White" />
                      <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentDark}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
            <Button Content="卡片"
                    Command="{Binding ToggleCardViewCommand}">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource ViewModeButtonStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ViewMode, Converter={StaticResource ViewModeToBool}, ConverterParameter=Card}" Value="True">
                      <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
                      <Setter Property="Foreground" Value="White" />
                      <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentDark}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
          </StackPanel>

          <StackPanel Orientation="Horizontal"
                      DockPanel.Dock="Right"
                      VerticalAlignment="Center">
            <Button Content="复制"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding CopySelectionCommand}"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    FontSize="12"
                    ToolTip="将选中第一条写回剪贴板 (Enter)" />
            <Button Content="合并"
                    Command="{Binding MergeSelectionCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    FontSize="12"
                    ToolTip="将选中的多条记录合并后同步到剪贴板" />
            <Button Content="编辑"
                    Command="{Binding EditSelectionCommand}"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    FontSize="12" />
            <Button Content="删除"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding DeleteSelectionCommand}"
                    Padding="12,8"
                    FontSize="12" />
          </StackPanel>

          <Border Margin="16,0,16,0"
                  VerticalAlignment="Center"
                  Background="{StaticResource Brush.Page}"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10,0,12,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="🔍"
                         Grid.Column="0"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         Opacity="0.55"
                         FontSize="13" />
              <TextBox Grid.Column="1"
                       MinWidth="180"
                       Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                       Background="Transparent"
                       BorderThickness="0"
                       Padding="0,8"
                       FontSize="13" />
            </Grid>
          </Border>
        </DockPanel>
      </Grid>
    </Border>

    <!-- List -->
    <Border Grid.Row="1"
            Margin="20,16,20,12"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="12,12,8,12">
      <ListBox x:Name="HistoryList"
               Style="{StaticResource HistoryListBox}"
               SelectionMode="Extended"
               ItemsSource="{Binding Items}"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling"
               SelectionChanged="HistoryList_OnSelectionChanged"
               MouseDoubleClick="HistoryList_OnMouseDoubleClick"
               ItemContainerStyle="{StaticResource HistoryListItem}">
        <ListBox.InputBindings>
          <KeyBinding Key="Enter" Command="{Binding CopySelectionCommand}" />
        </ListBox.InputBindings>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type models:ClipboardItem}">
            <Border Padding="12,10"
                    Background="#FAFBFC"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
              <Grid>
                <!-- Text / File Preview -->
                <TextBlock Text="{Binding Preview}"
                           Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=Text}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource Brush.Text}"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModeToWrapping}}"
                           MaxHeight="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ViewModeToMaxHeight}}" />
                <TextBlock Text="{Binding Preview}"
                           Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=File}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="12"
                           FontStyle="Italic" />
                <!-- Image Preview -->
                <Image Source="{Binding ImageData, Converter={StaticResource BytesToImage}}"
                       Visibility="{Binding Type, Converter={StaticResource TypeToVisibility}, ConverterParameter=Image}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Status -->
    <Border Grid.Row="2"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Padding="20,12">
      <TextBlock Text="{Binding StatusHint}"
                 Foreground="{StaticResource Brush.TextMuted}"
                 FontSize="12"
                 LineHeight="18"
                 TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
